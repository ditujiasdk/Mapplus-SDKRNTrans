{
  "name": "AwesomeProject",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package",
    "dev": "react-native bundle-harmony --dev",
    "codegen": "react-native codegen-harmony --cpp-output-path ./harmony/entry/src/main/cpp/generated --rnoh-module-path ./harmony/entry/oh_modules/@rnoh/react-native-openharmony"
    
  },
  "codegenConfig": {
    "name": "NativeSpec",
    "type": "modules",
    "jsSrcsDir": "src/specs/v1"
  },
  "harmony": {
    "codegenConfig": [
      {
        "version": 1,
        "specPaths": [
          "./src/specs/v1"
        ]
      }
    ]
  },
  "dependencies": {
    "@mapplus/react-native-webmap": "^0.0.7",
    "@react-native-oh-tpl/react-native-safe-area-context": "^4.7.4-0.2.1",
    "@react-native-oh-tpl/react-native-webview": "^13.10.3",
    "@react-native-oh/react-native-harmony": "^0.72.119",
    "@react-native-ohos/react-native-fs": "^2.20.1-rc.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.19",
    "patch-package": "^8.0.1",
    "react": "18.2.0",
    "react-native": "0.72.5",
    "react-native-easy-toast": "2.3.0",
    "react-native-fs": "2.20.0",
    "react-native-gesture-handler": "2.14.1",
    "react-native-safe-area-context": "4.7.4",
    "react-native-screens": "3.29.0",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@eslint/config-helpers": "^0.5.5",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.57.1",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "popular": "^0.0.1-security",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=16"
  }
}
